rules_version = '2';

// Notka — Firestore Security Rules (Фаза 0)
//
// Канонический идентификатор: uid == Spotify ID (выдаётся Cloud Function
// exchangeSpotifyToken). Поэтому request.auth.uid совпадает с полем `odl`
// и с ключами документов users/{odl}. `userId` — легаси-поле iOS,
// поддерживается на переходный период.
//
// Главное отличие от прежней версии: добавлена ПРИВЯЗКА К request.auth.uid.
// Раньше проверки структуры были, но без аутентификации — кто угодно мог
// писать документы с чужим odl. Соглашения по ID документов
// (likes = {odl}_{scrobbleId}, followers = {followerId}_{followingId})
// сохранены.
//
// ⚠️ Каркас — выверить на эмуляторе (firebase emulators:start) перед прод-деплоем.
// Деплоить ТОЛЬКО после того, как веб реально логинится в Firebase Auth,
// иначе все запросы станут unauthenticated и приложение «ослепнет».

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    // владелец нового документа (по полю odl или легаси userId)
    function ownsNew() {
      return signedIn() && (
        uid() == request.resource.data.odl ||
        uid() == request.resource.data.userId
      );
    }
    // владелец существующего документа
    function ownsExisting() {
      return signedIn() && (
        uid() == resource.data.odl ||
        uid() == resource.data.userId
      );
    }

    // USERS: id документа == spotifyId == uid (для iOS — Firebase Auth UID)
    match /users/{userId} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && uid() == userId;
      allow update: if signedIn() && (
        uid() == userId
        // ⚠️ ВРЕМЕННО: при follow/unfollow клиент инкрементит счётчики на
        // ЧУЖОМ документе. Разрешаем менять ТОЛЬКО эти поля. Правильный фикс —
        // перенести инкременты в Cloud Functions (onFollowCreated/onFollowDeleted)
        // и убрать клиентскую запись; тогда эту ветку удалить.
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['followersCount', 'followingCount'])
      );

      // BLOCKED_USERS (iOS): подколлекция блокировок — только владелец списка.
      match /blocked_users/{blockedId} {
        allow read, write: if signedIn() && uid() == userId;
      }
    }

    // SCROBBLES: читают все авторизованные (лента/дискавери); пишет владелец.
    // likesCount меняет ТОЛЬКО Cloud Function (admin обходит правила).
    match /scrobbles/{scrobbleId} {
      allow read: if signedIn();
      allow create: if ownsNew()
                    && request.resource.data.title is string
                    && request.resource.data.artist is string
                    && request.resource.data.timestamp != null;
      allow update, delete: if ownsExisting();
    }

    // LIKES: id == {odl}_{scrobbleId}. Лайкающий владеет своим лайком.
    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if ownsNew()
                    && request.resource.data.scrobbleId is string
                    && likeId == request.resource.data.odl + '_' + request.resource.data.scrobbleId;
      allow delete: if ownsExisting()
                    && likeId.matches('^' + resource.data.odl + '_.*');
    }

    // FOLLOWERS: id == {followerId}_{followingId}. Владеет подписчик.
    match /followers/{followId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && uid() == request.resource.data.followerId
                    && followId == request.resource.data.followerId + '_' + request.resource.data.followingId;
      allow delete: if signedIn() && uid() == resource.data.followerId;
    }

    // CHATS (iOS): доступ только участникам (participantIds).
    match /chats/{chatId} {
      allow read:   if signedIn() && uid() in resource.data.participantIds;
      allow create: if signedIn() && uid() in request.resource.data.participantIds;
      allow update: if signedIn() && uid() in resource.data.participantIds;
      allow delete: if false;

      // MESSAGES: писать может только отправитель и только в свой чат;
      // читать/обновлять (isRead, likedBy) — любой участник.
      match /messages/{messageId} {
        function chatParticipants() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        }
        allow read:   if signedIn() && uid() in chatParticipants();
        allow create: if signedIn()
                      && uid() == request.resource.data.senderId
                      && uid() in chatParticipants();
        allow update: if signedIn() && uid() in chatParticipants();
        allow delete: if false;
      }
    }

    // NOTIFICATIONS: создаёт ТОЛЬКО Cloud Function. Получатель (odl) читает/удаляет.
    match /notifications/{notificationId} {
      allow read, delete: if signedIn() && uid() == resource.data.odl;
      allow update: if signedIn() && uid() == resource.data.odl
                    && request.resource.data.read is bool;
      allow create: if false;
    }

    // SUGGESTIONS: отправитель владеет рекомендацией.
    // ⚠️ Расхождение схемы: web использует fromId/toId, iOS — fromUserId/toUserId.
    // Терпим к обоим до унификации. (Отдельно: Cloud Function onSuggestionCreated
    // читает fromId/toId и НЕ срабатывает на iOS-документах — починить функцию.)
    match /suggestions/{suggestionId} {
      allow read: if signedIn() && (
        uid() == resource.data.fromId || uid() == resource.data.toId ||
        uid() == resource.data.fromUserId || uid() == resource.data.toUserId
      );
      allow create: if signedIn() && (
        uid() == request.resource.data.fromId ||
        uid() == request.resource.data.fromUserId
      );
      // получатель помечает прочитанным
      allow update: if signedIn() && (
        uid() == resource.data.toId || uid() == resource.data.toUserId
      );
      allow delete: if signedIn() && (
        uid() == resource.data.fromId || uid() == resource.data.fromUserId
      );
    }

    // Default deny — всё, что не описано выше, запрещено.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
